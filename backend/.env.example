DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dlms_assistant

# Host-run default. Docker Compose overrides this to host.docker.internal.
# For Podman Compose, set OLLAMA_HOST=host.containers.internal before startup.
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_LLM_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# JWT Authentication
JWT_SECRET=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARS
JWT_EXPIRY_MS=3600000
REFRESH_EXPIRY_MS=2592000000

# Audit HMAC signing key (minimum 32 characters)
AUDIT_HMAC_KEY=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARS

# Session encryption key (exactly 16 characters for AES-128)
SESSION_ENCRYPTION_KEY=SAMPLE_AES_16KEY

# MCP Server URL
MCP_SERVER_URL=http://mcp-server:8001
